{
  "python.defaultInterpreterPath": "${workspaceFolder}/backend/venv/bin/python3",
  "python.pythonPath": "${workspaceFolder}/backend/venv/bin/python3",
  "python.analysis.extraPaths": [
    "${workspaceFolder}/backend/venv/lib/python3.13/site-packages"
